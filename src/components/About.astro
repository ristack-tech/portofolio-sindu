---
const skills = [
  { category: "Frontend", items: ["React / Next.js", "TypeScript", "Astro", "Tailwind CSS", "GSAP / Framer Motion"] },
  { category: "Backend", items: ["Node.js", "Python", "PostgreSQL", "Redis", "GraphQL"] },
  { category: "Design", items: ["Figma", "Adobe XD", "Photoshop", "After Effects", "Blender"] },
  { category: "DevOps", items: ["Docker", "AWS", "Vercel", "GitHub Actions", "Linux"] }
];
---

<section id="about" class="border-b-[8px] border-black bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
      <div class="lg:col-span-5">
        <div class="section-header flex items-center gap-6 mb-8">
          <span class="font-mono text-xs font-bold bg-black text-white px-4 py-2">02</span>
          <h2 class="font-display text-4xl md:text-5xl font-extrabold">ABOUT</h2>
        </div>

        <div class="about-image relative">
          <div class="aspect-square bg-[#e8e8e8] border-[4px] border-black relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-br from-[#e8e8e8] to-[#d0d0d0] flex items-center justify-center">
              <span class="font-display text-8xl font-extrabold text-[#c2c6d6]">SA</span>
            </div>
            <div class="absolute bottom-0 left-0 right-0 h-16 bg-[#0058be]"></div>
          </div>
          <div class="absolute -bottom-6 -right-6 aspect-square bg-[#dadada] border-[4px] border-black -z-10"></div>
        </div>

        <div class="social-links flex gap-4 mt-10">
          <a href="#" class="social-icon w-12 h-12 bg-[#f3f3f3] border-[2px] border-black flex items-center justify-center hover:bg-[#0058be] hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="#" class="social-icon w-12 h-12 bg-[#f3f3f3] border-[2px] border-black flex items-center justify-center hover:bg-[#0058be] hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="#" class="social-icon w-12 h-12 bg-[#f3f3f3] border-[2px] border-black flex items-center justify-center hover:bg-[#0058be] hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          </a>
          <a href="#" class="social-icon w-12 h-12 bg-[#f3f3f3] border-[2px] border-black flex items-center justify-center hover:bg-[#0058be] hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
        </div>
      </div>

      <div class="lg:col-span-7">
        <div class="sticky top-32">
          <h3 class="about-heading font-display text-3xl md:text-4xl font-extrabold leading-tight mb-8">
            Creative developer dengan passion untuk membangun<br/>
            <span class="text-[#0058be]">digital products</span> yang memorable.
          </h3>

          <div class="about-text space-y-6 font-body text-lg text-[#424754] leading-relaxed">
            <p>
              Based di Jakarta, aku sudah menghabiskan 5+ tahun terakhir fokus di intersection antara design dan development. Approach aku simpel: kombinasikan technical excellence dengan visual boldness.
            </p>
            <p>
              Aku percaya good design itu gak harus soft. Kadang yang paling memorable itu yang paling berani — thick borders, high contrast, dan elements that demand attention.
            </p>
            <p>
              Saat ini open untuk freelance projects dan collaboration. Kalau kamu punya vision yang gak konvensional, kita harus ngobrol.
            </p>
          </div>

          <div class="skills-section mt-12 pt-8 border-t-[4px] border-black">
            <h4 class="font-mono text-xs font-bold tracking-widest mb-6">TECHNICAL STACK</h4>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {skills.map((skill, index) => (
                <div class="skill-card bg-[#f3f3f3] border-[2px] border-black p-4">
                  <span class="font-mono text-xs font-bold text-[#0058be] block mb-2">{skill.category}</span>
                  <span class="font-body text-sm text-[#424754]">{skill.items.join(" • ")}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>