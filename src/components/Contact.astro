---
---

<section id="contact" class="border-b-[8px] border-black bg-white">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
      <div class="lg:col-span-6">
        <div class="section-header flex items-center gap-6 mb-8">
          <span class="font-mono text-xs font-bold bg-black text-white px-4 py-2">04</span>
          <h2 class="font-display text-4xl md:text-5xl font-extrabold">CONTACT</h2>
        </div>

        <h3 class="contact-heading font-display text-3xl md:text-4xl font-extrabold leading-tight mb-6">
          Punya project menarik?<br/>
          <span class="text-[#0058be]">Kita ngobrol.</span>
        </h3>

        <p class="contact-text font-body text-lg text-[#424754] leading-relaxed mb-8">
          Currently available untuk freelance work, consulting, dan exciting collaborations. response time biasanya dalam 24 jam.
        </p>

        <a href="mailto:hello@sinduaditya.com" class="contact-email inline-flex items-center gap-3 bg-[#0058be] text-white px-8 py-4 font-mono text-sm font-bold border-[4px] border-black shadow-[6px_6px_0_0_#000] hover:shadow-[8px_8px_0_0_#000] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          HELLO@SINDUADITYA.COM
        </a>

        <div class="contact-status mt-12 p-6 bg-[#f3f3f3] border-[4px] border-black">
          <div class="flex items-center gap-4">
            <div class="status-dot w-4 h-4 bg-green-500 border-[2px] border-black animate-pulse"></div>
            <span class="font-mono text-sm font-bold">AVAILABLE FOR NEW PROJECTS</span>
          </div>
          <p class="font-body text-sm text-[#424754] mt-3">typically responds within 24 hours</p>
        </div>
      </div>

      <div class="lg:col-span-6">
        <form class="contact-form bg-[#f3f3f3] border-[4px] border-black p-8 shadow-[6px_6px_0_0_#000]">
          <div class="form-group mb-6">
            <label class="form-label font-mono text-xs font-bold tracking-widest mb-2 block">NAMA</label>
            <input type="text" class="form-input w-full bg-white border-[2px] border-black p-4 font-body text-[#1a1c1c] focus:border-[#0058be] focus:outline-none transition-colors placeholder:text-[#727785]" placeholder="Nama lengkap">
          </div>
          <div class="form-group mb-6">
            <label class="form-label font-mono text-xs font-bold tracking-widest mb-2 block">EMAIL</label>
            <input type="email" class="form-input w-full bg-white border-[2px] border-black p-4 font-body text-[#1a1c1c] focus:border-[#0058be] focus:outline-none transition-colors placeholder:text-[#727785]" placeholder="email@example.com">
          </div>
          <div class="form-group mb-6">
            <label class="form-label font-mono text-xs font-bold tracking-widest mb-2 block">SUBJEK</label>
            <input type="text" class="form-input w-full bg-white border-[2px] border-black p-4 font-body text-[#1a1c1c] focus:border-[#0058be] focus:outline-none transition-colors placeholder:text-[#727785]" placeholder="Project Inquiry">
          </div>
          <div class="form-group mb-6">
            <label class="form-label font-mono text-xs font-bold tracking-widest mb-2 block">MESSAGE</label>
            <textarea rows="5" class="form-textarea w-full bg-white border-[2px] border-black p-4 font-body text-[#1a1c1c] focus:border-[#0058be] focus:outline-none transition-colors resize-none placeholder:text-[#727785]" placeholder="Ceritain project kamu..."></textarea>
          </div>
          <button type="submit" class="submit-btn w-full bg-[#0058be] text-white py-4 font-mono text-sm font-bold border-[4px] border-black shadow-[6px_6px_0_0_#000] hover:shadow-[8px_8px_0_0_#000] hover:-translate-x-1 hover:-translate-y-1 transition-all duration-200">
            KIRIM MESSAGE
          </button>
        </form>
      </div>
    </div>
  </div>
</section>