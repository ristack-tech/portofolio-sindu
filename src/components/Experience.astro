---

<section id="experience" class="border-b-[8px] border-black bg-[#f3f3f3]">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20">
    <div class="section-header flex items-center gap-6 mb-16">
      <span class="font-mono text-xs font-bold bg-black text-white px-4 py-2">03</span>
      <div>
        <h2 class="font-display text-4xl md:text-5xl font-extrabold">EXPERIENCE</h2>
        <p class="font-body text-[#424754] mt-1">Perjalanan dari kepanitiaan, magang, sampai memimpin produk di produksi.</p>
      </div>
    </div>

    <div class="space-y-6">
      {experience.map((exp, index) => (
        <div class="exp-item grid grid-cols-1 md:grid-cols-12 gap-6 items-start">
          <div class="md:col-span-3 exp-period">
            <span class="font-mono text-xs font-bold text-[#727785] block">{exp.period}</span>
            <span class="font-mono text-xs text-[#727785] block mt-1">{exp.location}</span>
          </div>
          <div class="md:col-span-9 bg-white border-[4px] border-black p-6 exp-card">
            <div class="flex items-start justify-between flex-wrap gap-4 mb-3">
              <div>
                <h4 class="font-display text-xl font-bold">{exp.role}</h4>
                <p class="font-body text-[#0058be] font-medium">{exp.company}</p>
              </div>
              <span class="exp-badge font-mono text-xs font-bold bg-[#d8e2ff] text-[#001a42] px-3 py-1 border-[2px] border-black">{String(index + 1).padStart(2, '0')}</span>
            </div>
            <p class="font-body text-[#1a1c1c] leading-relaxed">{exp.summary}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
