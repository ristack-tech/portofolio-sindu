---
import Layout from '../../layouts/Layout.astro';

const projects = [
  {
    slug: "suite-aplikasi-bisnis",
    title: "Suite Aplikasi Bisnis Modular",
    client: "PT. Lims Yanwo Indonesia",
    description: "ERP modular 4-modul (QC, Inventory, Absensi, Payroll) untuk lini produksi manufaktur.",
    problem: "Lini produksi masih jalan di atas kertas dan spreadsheet — semua proses terpisah-pisah.",
    tags: ["LARAVEL", "MULTI-MODUL", "ERP"],
    year: "2025",
    role: "Full-Stack Engineer & PM"
  },
  {
    slug: "fleettrack",
    title: "FleetTrack",
    client: "Lab IoT Nexa",
    description: "Backend MQTT-based untuk sistem fleet management IoT — pelacakan armada real-time.",
    problem: "Sensor armada IoT menghasilkan data real-time yang harus sampai ke dashboard dengan latensi rendah dan stabil.",
    tags: ["LARAVEL", "MQTT", "IOT"],
    year: "2025",
    role: "Backend Engineer"
  },
  {
    slug: "top-fik",
    title: "TOP FIK",
    client: "Bengkel Koding",
    description: "Platform multi-tenant untuk sistem informasi akademik lintas fakultas.",
    problem: "Sistem informasi akademik butuh melayani banyak fakultas dengan kebutuhan berbeda dari satu basis kode.",
    tags: ["LARAVEL", "MULTI-TENANT", "PM"],
    year: "2025",
    role: "Project Manager & Backend"
  },
  {
    slug: "klora",
    title: "Klora",
    client: "ECOTHON 2024 (Top 10 ASEAN)",
    description: "Platform daur ulang web + mobile dengan penjadwalan penjemputan dan konversi poin.",
    problem: "Pengelolaan sampah masih manual — tidak ada cara mudah menjadwalkan penjemputan dan memberi insentif ke pengguna.",
    tags: ["REACT NATIVE", "APPWRITE", "BAAAS"],
    year: "2024",
    role: "Core Team Lead"
  }
];
---

<Layout
  title="Projects — Sindu Aditya"
  description="Portofolio produk yang sudah saya bangun dari sketsa sampai live di produksi: ERP modular untuk lini produksi, fleet IoT dengan MQTT, platform multi-tenant, dan prototype daur ulang."
  ogImage="/og-default.png"
>
  <main class="pt-24 pb-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <!-- Header -->
      <div class="mb-16">
        <a href="/#work" class="inline-flex items-center gap-2 font-mono text-sm font-bold mb-8 hover:text-[#0058be] transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/>
          </svg>
          BACK TO HOME
        </a>
        <div class="flex items-center gap-6 mb-6">
          <span class="font-mono text-xs font-bold bg-black text-white px-4 py-2">01</span>
          <h1 class="font-display text-5xl md:text-7xl font-extrabold">SEMUA PROJECT</h1>
        </div>
        <p class="font-body text-xl text-[#424754] max-w-2xl">Setiap produk dimulai dari masalah. Koleksi project yang sudah saya bangun dari sketsa sampai live di produksi.</p>
      </div>

      <!-- Projects Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-16">
        {projects.map((project) => (
          <a href={`/projects/${project.slug}`} class="work-card group block bg-white border-[4px] border-black shadow-[6px_6px_0_0_#000] hover:shadow-[10px_10px_0_0_#000] hover:-translate-x-2 hover:-translate-y-2 transition-all duration-300 cursor-pointer">
            <div class="h-80 bg-[#e8e8e8] border-b-[4px] border-black relative overflow-hidden">
              <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-full h-full bg-gradient-to-br from-[#e8e8e8] to-[#d0d0d0] flex items-center justify-center">
                  <span class="font-display text-8xl font-extrabold text-[#c2c6d6]">{project.title.charAt(0)}</span>
                </div>
              </div>
              <div class="absolute top-4 right-4 font-mono text-xs font-bold text-[#727785]">{project.year}</div>
              <div class="work-overlay absolute inset-0 bg-[#0058be]/90 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                <span class="font-mono text-sm font-bold text-white border-[2px] border-white px-6 py-3">LIHAT PROJECT</span>
              </div>
            </div>

            <div class="p-8">
              <div class="flex flex-wrap gap-2 mb-4">
                {project.tags.map(tag => (
                  <span class="font-mono text-xs font-bold bg-[#d8e2ff] text-[#001a42] px-3 py-1 border-[2px] border-black">{tag}</span>
                ))}
              </div>
              <h2 class="font-display text-3xl font-bold mb-2 group-hover:text-[#0058be] transition-colors">{project.title}</h2>
              <p class="font-mono text-xs text-[#727785] mb-3">{project.role} · {project.client}</p>
              <p class="font-body text-[#1a1c1c] leading-relaxed mb-3"><span class="font-bold">Masalah:</span> {project.problem}</p>
              <p class="font-body text-[#424754] leading-relaxed mb-4">{project.description}</p>
              <div class="pt-4 border-t-[2px] border-black">
                <span class="font-mono text-xs text-[#727785]">LIHAT DETAIL </span>
                <span class="font-mono text-xs font-bold text-[#0058be]">→</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- Back Link -->
      <div class="text-center pt-8 border-t-[4px] border-black">
        <a href="/#work" class="inline-flex items-center gap-2 bg-black text-white px-8 py-4 font-mono text-sm font-bold border-[4px] border-black hover:bg-[#0058be] transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/>
          </svg>
          BACK TO HOME
        </a>
      </div>
    </div>
  </main>
</Layout>
