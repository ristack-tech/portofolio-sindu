---
import Layout from '../../layouts/Layout.astro';

const project = {
  title: "Velocity Media",
  description: "Platform content management untuk tim kreatif dengan workflow automation.",
  tags: ["NEXT.JS", "NODE.JS", "POSTGRESQL"],
  year: "2024",
  role: "Full Stack Developer",
  client: "Velocity Media Group",
  fullDescription: "Velocity Media adalah platform content management yang dirancang untuk tim kreatif dalam mengelola workflow produksi konten digital. Platform ini menyediakan sistem manajemen aset digital, collaboration tools, dan workflow automation.",
  features: [
    "Digital Asset Management system",
    "Workflow automation dengan approval process",
    "Real-time collaboration tools",
    "Multi-user access dengan role management",
    "Content scheduling dan publishing calendar"
  ],
  techStack: ["Next.js 14", "Node.js", "PostgreSQL", "Redis", "AWS S3", "Tailwind CSS"]
};
---

<Layout title={`${project.title} | Sindu Aditya`}>
  <main class="pt-24 pb-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <a href="/#work" class="inline-flex items-center gap-2 font-mono text-sm font-bold mb-8 hover:text-[#0058be] transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/>
        </svg>
        BACK TO WORK
      </a>

      <div class="mb-16">
        <span class="font-mono text-xs font-bold bg-black text-white px-4 py-2 mb-6 inline-block">{project.year}</span>
        <h1 class="font-display text-5xl md:text-7xl font-extrabold mb-6">{project.title}</h1>
        <p class="font-body text-xl text-[#424754] max-w-3xl">{project.description}</p>
      </div>

      <div class="aspect-video bg-[#e8e8e8] border-[4px] border-black mb-16 flex items-center justify-center">
        <span class="font-display text-8xl font-extrabold text-[#c2c6d6]">{project.title.charAt(0)}</span>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 mb-16">
        <div class="lg:col-span-4 space-y-8">
          <div class="bg-[#f3f3f3] border-[4px] border-black p-6">
            <h3 class="font-mono text-xs font-bold tracking-widest mb-4">PROJECT INFO</h3>
            <div class="space-y-4">
              <div>
                <span class="font-mono text-xs text-[#727785] block">ROLE</span>
                <span class="font-body text-[#1a1c1c]">{project.role}</span>
              </div>
              <div>
                <span class="font-mono text-xs text-[#727785] block">CLIENT</span>
                <span class="font-body text-[#1a1c1c]">{project.client}</span>
              </div>
              <div>
                <span class="font-mono text-xs text-[#727785] block">YEAR</span>
                <span class="font-body text-[#1a1c1c]">{project.year}</span>
              </div>
            </div>
          </div>

          <div class="bg-[#f3f3f3] border-[4px] border-black p-6">
            <h3 class="font-mono text-xs font-bold tracking-widest mb-4">TECH STACK</h3>
            <div class="flex flex-wrap gap-2">
              {project.tags.map(tag => (
                <span class="font-mono text-xs font-bold bg-[#d8e2ff] text-[#001a42] px-3 py-1 border-[2px] border-black">{tag}</span>
              ))}
            </div>
          </div>
        </div>

        <div class="lg:col-span-8">
          <h2 class="font-display text-3xl font-extrabold mb-6">About This Project</h2>
          <p class="font-body text-lg text-[#424754] leading-relaxed mb-8">{project.fullDescription}</p>

          <h3 class="font-display text-2xl font-extrabold mb-4">Key Features</h3>
          <ul class="space-y-3 mb-8">
            {project.features.map(feature => (
              <li class="flex items-start gap-3">
                <span class="w-2 h-2 bg-[#0058be] mt-2 flex-shrink-0"></span>
                <span class="font-body text-[#424754]">{feature}</span>
              </li>
            ))}
          </ul>

          <h3 class="font-display text-2xl font-extrabold mb-4">Tech Stack</h3>
          <ul class="flex flex-wrap gap-3">
            {project.techStack.map(tech => (
              <li class="font-mono text-sm font-bold text-[#1a1c1c] bg-white border-[2px] border-black px-4 py-2">{tech}</li>
            ))}
          </ul>
        </div>
      </div>

      <div class="flex justify-between items-center pt-8 border-t-[4px] border-black">
        <a href="/#work" class="inline-flex items-center gap-2 bg-black text-white px-6 py-3 font-mono text-sm font-bold border-[4px] border-black hover:bg-[#0058be] transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/>
          </svg>
          PREV PROJECT
        </a>
        <a href="/#work" class="inline-flex items-center gap-2 bg-white text-[#1a1c1c] px-6 py-3 font-mono text-sm font-bold border-[4px] border border-black hover:bg-[#f3f3f3] transition-colors">
          NEXT PROJECT
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </main>
</Layout>